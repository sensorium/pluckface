@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

<urn:sensorium:pluckface>
	a lv2:Plugin ;
	lv2:binary <pluckface.dylib>  ;
	rdfs:seeAlso 	<pluckface.ttl> .
@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<urn:sensorium:pluckface>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-pluckface.html> ;
        modgui:stylesheet <modgui/stylesheet-pluckface.css> ;
        modgui:javascript <modgui/pluckface.js> ;
        modgui:screenshot <modgui/screenshot-pluckface.png> ;
        modgui:thumbnail <modgui/thumbnail-pluckface.png> ;
        modgui:monitoredOutputs [
            lv2:symbol "input_level_db" ;
        ] , [
            lv2:symbol "cv_out_meter" ;
        ] , [
            lv2:symbol "onset_indicator" ;
        ]
    ] .